# Google Places API key for GetRestaurantNearby
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# OpenAI API key for AI-based menu extraction and nutrition estimation
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI model to use for AI features
OPENAI_MODEL=gpt-4o-mini

# USDA FoodData Central API key for nutrition data
USDA_API_KEY=your_usda_api_key_here

# User profile storage path (JSON file)
USER_PROFILE_STORAGE_PATH=./data/user_profiles.json

# Restaurant cache TTL in seconds (default: 300 = 5 minutes)
RESTAURANT_CACHE_TTL=300

# Maximum restaurants to cache
RESTAURANT_CACHE_MAXSIZE=1000
